# ============================================
# DATABASE PROVIDER SWITCH
# Options: "neon", "supabase", "aiven"
# ============================================
ACTIVE_DB_PROVIDER="supabase"
NEON_DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"
SUPABASE_DATABASE_URL="postgres://user:password@host:6543/postgres?sslmode=require"
AIVEN_DATABASE_URL="postgres://avnadmin:password@host:port/defaultdb?sslmode=require"
JWT_SECRET="your_jwt_secret_here"
ADMIN_PASSWORD_HASH="your_admin_password_hash_here"
ADMIN_PASSWORD="initial_password_for_seeding"
SENDER_EMAIL="nongorr.anika@gmail.com"
SENDGRID_API_KEY="your_sendgrid_key_here"

# TOTP Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOTP_ENCRYPTION_KEY="your_64_char_hex_key_here"

# MFA Password Reset Configuration
RESET_TOKEN_PEPPER="random_32_char_secret_here"
TELEGRAM_OTP_PEPPER="another_random_32_char_secret"
RESET_TOKEN_TTL_MINUTES=10
TELEGRAM_OTP_TTL_MINUTES=7
OTP_MAX_ATTEMPTS=5

# Telegram Bot (for password reset OTP)
TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"
ADMIN_TELEGRAM_CHAT_ID="your_telegram_chat_id"

# TOTP Configuration
TOTP_ISSUER="Nongor"
TOTP_LABEL="NongorAdmin"

# Web Push Notifications (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"
VAPID_SUBJECT="mailto:nongorr.anika@gmail.com"
